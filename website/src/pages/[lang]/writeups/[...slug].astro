---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { LANGS, type Lang } from "../../../config/site";
import {
  formatDate,
  getEntriesByLang,
  getPostSlug,
  isWriteupEntry,
  renderMarkdown,
  sortByDateDesc,
} from "../../../lib/content";

export async function getStaticPaths() {
  const paths: Array<{ params: { lang: Lang; slug: string }; props: { lang: Lang; writeup: any } }> = [];

  for (const lang of LANGS) {
    const entries = getEntriesByLang(lang);
    for (const writeup of sortByDateDesc(entries.filter(isWriteupEntry))) {
      paths.push({
        params: {
          lang,
          slug: getPostSlug(writeup),
        },
        props: { lang, writeup },
      });
    }
  }

  return paths;
}

const { writeup, lang } = Astro.props;
const html = renderMarkdown(writeup.body);

type TocLevel = 1 | 2;
type TocItem = { level: TocLevel; id: string; text: string; parentId?: string };
type TocGroup = { id: string; text: string; children: Array<{ id: string; text: string }> };

function stripTags(value: string): string {
  return value
    .replace(/<[^>]+>/g, "")
    .replace(/&amp;/g, "&")
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .trim();
}

function slugifyHeading(input: string): string {
  return input
    .toLowerCase()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9\s-]/g, "")
    .trim()
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-");
}

const usedHeadingIds = new Map<string, number>();
const tocItems: TocItem[] = [];
let currentH1Id: string | undefined;

const htmlWithHeadingIds = html.replace(/<h([23])([^>]*)>([\s\S]*?)<\/h\1>/g, (full, levelRaw, attrsRaw, inner) => {
  const level = Number(levelRaw) as TocLevel;
  const text = stripTags(inner);
  if (!text) {
    return full;
  }

  const attrs = String(attrsRaw ?? "");
  const existingIdMatch = attrs.match(/\sid=["']([^"']+)["']/i);
  let id = existingIdMatch?.[1] ?? slugifyHeading(text);

  const seen = usedHeadingIds.get(id) ?? 0;
  usedHeadingIds.set(id, seen + 1);
  if (seen > 0) {
    id = `${id}-${seen + 1}`;
  }

  const attrsWithoutId = attrs.replace(/\sid=["'][^"']+["']/i, "");
  if (level === 2) {
    currentH1Id = id;
    tocItems.push({ level, id, text });
  } else {
    tocItems.push({ level, id, text, parentId: currentH1Id });
  }

  return `<h${level}${attrsWithoutId} id="${id}">${inner}</h${level}>`;
});

const tocGroups: TocGroup[] = [];
for (const item of tocItems) {
  if (item.level === 2) {
    tocGroups.push({ id: item.id, text: item.text, children: [] });
    continue;
  }

  const parent = item.parentId ? tocGroups.find((group) => group.id === item.parentId) : tocGroups.at(-1);
  if (parent) {
    parent.children.push({ id: item.id, text: item.text });
  } else {
    tocGroups.push({ id: item.id, text: item.text, children: [] });
  }
}

const hasToc = tocGroups.length > 0;
---

<BaseLayout title={writeup.data.title ?? "Write-up"} lang={lang} description={writeup.data.description}>
  <div class="article-page">
    <div class={`article-shell ${!hasToc ? "no-toc" : ""}`}>
      {hasToc && (
        <aside class="article-toc" data-toc>
          <div class="toc-header" data-toc-toggle>
            {lang === "tr" ? "Bölüm Menüsü" : "On this page"}
          </div>

          <nav class="toc-dropdown" data-toc-dropdown>
            {tocGroups.map((group) => (
              <section class="toc-group" data-group-id={group.id}>
                <a class="toc-link toc-link-h1" href={`#${group.id}`} data-toc-link data-heading-id={group.id} data-level="h1">
                  {group.text}
                </a>

                {group.children.length > 0 && (
                  <div class="toc-children">
                    {group.children.map((child) => (
                      <a
                        class="toc-link toc-link-h2"
                        href={`#${child.id}`}
                        data-toc-link
                        data-heading-id={child.id}
                        data-level="h2"
                        data-parent-id={group.id}
                      >
                        {child.text}
                      </a>
                    ))}
                  </div>
                )}
              </section>
            ))}
          </nav>
        </aside>
      )}

      <article class="markdown-content">
        <h1 class="title">{writeup.data.title}</h1>
        <p class="article-meta">{formatDate(writeup.data.date, lang)}</p>

        {writeup.data.featuredImage && (
          <img class="article-cover" src={writeup.data.featuredImage} alt={writeup.data.title} />
        )}

        <Fragment set:html={htmlWithHeadingIds} />
      </article>
    </div>
  </div>

  {hasToc && (
    <script is:inline>
      (() => {
        const toc = document.querySelector("[data-toc]");
        if (!toc) return;

        const toggle = toc.querySelector("[data-toc-toggle]");
        const dropdown = toc.querySelector("[data-toc-dropdown]");
        const groups = Array.from(toc.querySelectorAll(".toc-group"));
        const links = Array.from(toc.querySelectorAll("[data-toc-link]"));

        const openGroup = (groupId) => {
          groups.forEach((group) => {
            group.classList.toggle("is-open", group.dataset.groupId === groupId);
          });
        };

        const activateLink = (headingId) => {
          links.forEach((link) => {
            link.classList.toggle("is-active", link.dataset.headingId === headingId);
          });

          const active = links.find((link) => link.dataset.headingId === headingId);
          if (!active) return;

          const groupId = active.dataset.level === "h2" ? active.dataset.parentId : active.dataset.headingId;
          if (groupId) {
            openGroup(groupId);
          }
        };

        const headingNodes = links
          .map((link) => document.getElementById(link.dataset.headingId || ""))
          .filter(Boolean);

        const updateActiveByScroll = () => {
          if (!headingNodes.length) return;

          let current = headingNodes[0];
          for (const node of headingNodes) {
            const top = node.getBoundingClientRect().top;
            if (top <= 140) {
              current = node;
            } else {
              break;
            }
          }

          if (current?.id) {
            activateLink(current.id);
          }
        };

        links.forEach((link) => {
          link.addEventListener("click", () => {
            const headingId = link.dataset.headingId;
            if (!headingId) return;
            activateLink(headingId);
            if (window.innerWidth <= 1024 && dropdown) {
              dropdown.classList.remove("is-open");
            }
          });
        });

        if (toggle && dropdown) {
          toggle.addEventListener("click", () => {
            dropdown.classList.toggle("is-open");
          });
        }

        let ticking = false;
        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            updateActiveByScroll();
            ticking = false;
          });
        };

        window.addEventListener("scroll", onScroll, { passive: true });
        updateActiveByScroll();
      })();
    </script>
  )}
</BaseLayout>
