---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { LANGS, type Lang } from "../../config/site";
import { getStaticPage, isLang, renderMarkdown } from "../../lib/content";

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang ?? "tr";
if (!isLang(langParam)) {
  return Astro.redirect("/tr/about/");
}
const lang = langParam as Lang;

const aboutPage = getStaticPage(lang, "about");
const html = renderMarkdown(aboutPage?.body ?? "");
const title = aboutPage?.title ?? (lang === "tr" ? "Hakkimda" : "About");
---

<BaseLayout title={title} lang={lang} description={aboutPage?.description}>
  <article class="markdown-content">
    <h1 class="title">{title}</h1>
    {aboutPage ? (
      <Fragment set:html={html} />
    ) : (
      <p>{lang === "tr" ? "Icerik yakinda eklenecek." : "Content will be added soon."}</p>
    )}
  </article>
</BaseLayout>