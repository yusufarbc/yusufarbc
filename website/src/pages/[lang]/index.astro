---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { LANGS, SITE, type Lang } from "../../config/site";
import { formatDate, isLang, isPostEntry, sortByDateDesc, getPostSlug, getEntriesByLang } from "../../lib/content";

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang ?? "tr";
if (!isLang(langParam)) {
  return Astro.redirect("/tr/");
}

const lang = langParam as Lang;
const entries = getEntriesByLang(lang);
const recentPosts = sortByDateDesc(entries.filter(isPostEntry)).slice(0, 6);
const pageTitle = `${SITE.author} | ${SITE.title}`;
---

<BaseLayout title={pageTitle} lang={lang}>
  <section class="centered">
    <div class="about" style="text-align: center;">
      <div class="avatar">
        <img src={SITE.avatar} alt={SITE.author} />
      </div>
      <h1>{SITE.author}</h1>
      <h2>Software & Security Engineer</h2>
      <div class="rotating-terms-container">
        <span class="rotating-term" id="rotating-term">Digital Sovereignty</span>
      </div>
      <ul class="social-list">
        {SITE.socials.map((social) => (
          <li>
            <a href={social.url} target="_blank" rel="noreferrer" aria-label={social.name}>
              <i class={social.icon}></i>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section>
    <h2>{lang === "tr" ? "Son Yazılar" : "Recent Posts"}</h2>
    <div class="posts-list-grid">
      {recentPosts.map((post) => (
        <article class="post-item">
          <a class="post-link" href={`/${lang}/blog/${getPostSlug(post)}/`}>
            <div class="blog-cover-wrap">
              {post.data.featuredImage ? (
                <img class="blog-cover" src={post.data.featuredImage} alt={post.data.title} loading="lazy" />
              ) : (
                <div class="blog-cover blog-cover-placeholder" aria-hidden="true"></div>
              )}
            </div>
            <div class="blog-card-body">
              <div class="post-meta">{formatDate(post.data.date, lang)}</div>
              <h3 class="post-title">{post.data.title}</h3>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .rotating-terms-container {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 0.5rem;
    min-height: 1.8rem;
    overflow: hidden;
  }

  .rotating-term {
    font-size: clamp(0.95rem, 2.5vw, 1.25rem);
    font-weight: 600;
    color: var(--app-accent-color);
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1), transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
  }

  .rotating-term.fade-out {
    opacity: 0;
    transform: translateY(-12px);
  }

  .rotating-term.fade-in-start {
    opacity: 0;
    transform: translateY(12px);
  }
</style>

<script>
  const terms = [
    "Digital Sovereignty",
    "Cloud-Native",
    "Open Source",
    "Data Privacy",
    "Next-Gen SOC",
    "Endpoint Protection",
    "Network Defense"
  ];
  
  let currentIndex = 0;
  const termEl = document.getElementById("rotating-term");
  
  if (termEl) {
    setInterval(() => {
      // Step 1: Fade and slide up
      termEl.classList.add("fade-out");
      
      setTimeout(() => {
        // Step 2: Change content
        currentIndex = (currentIndex + 1) % terms.length;
        termEl.textContent = terms[currentIndex];
        
        // Step 3: Transition setup (move to bottom, keep invisible)
        termEl.classList.remove("fade-out");
        termEl.classList.add("fade-in-start");
        
        // Force reflow/layout recalculation to apply the class immediately without transitioning
        void termEl.offsetWidth;
        
        // Step 4: Slide up to center and fade in
        termEl.classList.remove("fade-in-start");
      }, 400); // matches transition duration
    }, 2800); // interval duration
  }
</script>