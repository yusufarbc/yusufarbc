---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { LANGS, type Lang } from "../../../config/site";
import { formatDate, getEntriesByLang, getPostSlug, isLang, isPostEntry, sortByDateDesc } from "../../../lib/content";

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang ?? "tr";
if (!isLang(langParam)) {
  return Astro.redirect("/tr/blog/");
}

const lang = langParam as Lang;
const posts = sortByDateDesc(getEntriesByLang(lang).filter(isPostEntry));
const title = lang === "tr" ? "Blog" : "Blog";
const years = Array.from(
  new Set(
    posts
      .map((post) => String(post.data.date ?? "").slice(0, 4))
      .filter((year) => /^\d{4}$/.test(year)),
  ),
).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title={title} lang={lang}>
  <section class="blog-hero">
    <h1 class="title">{title}</h1>
  </section>

  <section>
    <div id="blog-grid" class="posts-list-grid blog-grid">
      {posts.map((post) => (
        <article
          class="post-item blog-card"
          data-title={String(post.data.title ?? "").toLowerCase()}
          data-description={String(post.data.description ?? "").toLowerCase()}
          data-year={String(post.data.date ?? "").slice(0, 4)}
          data-date={String(new Date(post.data.date ?? 0).getTime())}
        >
          <a class="post-link" href={`/${lang}/blog/${getPostSlug(post)}/`}>
            <div class="blog-cover-wrap">
              {post.data.featuredImage ? (
                <img class="blog-cover" src={post.data.featuredImage} alt={post.data.title} loading="lazy" />
              ) : (
                <div class="blog-cover blog-cover-placeholder" aria-hidden="true"></div>
              )}
            </div>
            <div class="blog-card-body">
              <div class="post-meta">{formatDate(post.data.date, lang)}</div>
              <h2 class="post-title">{post.data.title}</h2>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>

  <script>
    const cards = Array.from(document.querySelectorAll(".blog-card"));

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 },
    );

    cards.forEach((card, index) => {
      card.style.transitionDelay = `${Math.min(index, 10) * 40}ms`;
      observer.observe(card);
    });
  </script>
</BaseLayout>
