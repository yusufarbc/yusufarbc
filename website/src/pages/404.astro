---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404: Page Not Found / Sayfa Bulunamadı" lang="tr">
  <section class="centered">
    <div style="text-align: center; padding: 4rem 1.5rem; max-width: 600px; margin: 0 auto;">
      <h1 style="font-size: clamp(4rem, 15vw, 7rem); font-weight: 900; line-height: 1; margin: 0; color: var(--app-accent-color);">404</h1>
      <h2 style="font-size: clamp(1.25rem, 4vw, 2rem); font-weight: 800; margin-top: 1rem; margin-bottom: 1.5rem; letter-spacing: -0.02em;">
        Page Not Found / Sayfa Bulunamadı
      </h2>
      <p style="font-size: 1.05rem; color: var(--app-text-dim); line-height: 1.7; margin-bottom: 2.5rem;">
        Aradığınız sayfa taşınmış, silinmiş veya geçici olarak kullanılamıyor olabilir.<br/>
        <span style="font-size: 0.95rem; opacity: 0.85;">The page you are looking for might have been removed, renamed, or is temporarily unavailable.</span>
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/tr/" class="tag" style="padding: 0.6rem 1.5rem; font-size: 0.95rem; border-radius: 99px;">
          Türkçe Ana Sayfa
        </a>
        <a href="/en/" class="tag" style="padding: 0.6rem 1.5rem; font-size: 0.95rem; border-radius: 99px;">
          English Home
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
