---
import "@fortawesome/fontawesome-free/css/all.min.css";
import "@fontsource/inter/300.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/inter/800.css";
import "@fontsource/inter/900.css";
import "../styles/base.css";
import type { Lang } from "../config/site";
import { MENU, SITE } from "../config/site";
import { resolveAssetPath } from "../lib/content";
import { Image } from "astro:assets";

interface Props {
  title: string;
  lang: Lang;
  description?: string;
}

const { title, lang, description } = Astro.props;
const oppositeLang: Lang = lang === "tr" ? "en" : "tr";
const pathname = Astro.url.pathname;
const switchedPath = pathname.replace(/^\/(tr|en)(?=\/|$)/, `/${oppositeLang}`);
const defaultDescription = SITE.description[lang] ?? SITE.description.en;
const pageDescription = description ?? defaultDescription;
const siteUrl = SITE.url;
const canonicalUrl = new URL(resolveAssetPath(pathname), siteUrl).toString();
const trPath = pathname.replace(/^\/(tr|en)(?=\/|$)/, "/tr");
const enPath = pathname.replace(/^\/(tr|en)(?=\/|$)/, "/en");
const trUrl = new URL(resolveAssetPath(trPath), siteUrl).toString();
const enUrl = new URL(resolveAssetPath(enPath), siteUrl).toString();
const ogImagePath = SITE.ogImage ?? SITE.avatar;
const ogImageUrl = new URL(resolveAssetPath(ogImagePath), siteUrl).toString();
const sitemapUrl = new URL(resolveAssetPath("/sitemap-index.xml"), siteUrl).toString();
const xDefaultUrl = new URL(resolveAssetPath("/tr/"), siteUrl).toString();
const ogLocale = lang === "tr" ? "tr_TR" : "en_US";
const ogLocaleAlt = lang === "tr" ? "en_US" : "tr_TR";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="author" content={SITE.author} />
    <meta name="robots" content="index,follow" />

    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" href={trUrl} hreflang="tr" />
    <link rel="alternate" href={enUrl} hreflang="en" />
    <link rel="alternate" href={xDefaultUrl} hreflang="x-default" />
    <link rel="icon" type="image/x-icon" href={resolveAssetPath("/favicon.ico")} />
    <link rel="sitemap" type="application/xml" href={sitemapUrl} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script is:inline>
      (() => {
        const remembered = localStorage.getItem("colorscheme");
        const isDark = remembered ? remembered === "dark" : window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.style.colorScheme = isDark ? "dark" : "light";
      })();
    </script>
  </head>
  <body class="preload-transitions colorscheme-auto">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div id="scroll-progress" class="scroll-progress"></div>

    <nav class="navigation" aria-label="Primary">
      <div class="container">
        <a class="navigation-title" href={`/${lang}/`} aria-label="Go to home">
          <Image class="navigation-logo" src={SITE.avatar} alt={SITE.author} width={32} height={32} />
          <span>{SITE.title}</span>
        </a>

        <button
          class="menu-toggle btn-reset"
          id="menu-toggle"
          aria-label="Toggle menu"
          aria-controls="navigation-list"
          aria-expanded="false"
        >
          <span class="hamburger-box">
            <span class="hamburger-inner"></span>
          </span>
        </button>

        <ul class="navigation-list" id="navigation-list">
          {MENU[lang].map((item) => (
            <li>
              <a
                class={`navigation-link ${pathname.startsWith(item.href) ? "is-active" : ""}`}
                href={item.href}
                aria-current={pathname.startsWith(item.href) ? "page" : undefined}
                target={item.external ? "_blank" : undefined}
                rel={item.external ? "noreferrer noopener" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a class="navigation-link" href={switchedPath || `/${oppositeLang}/`} aria-label="Switch language">
              {oppositeLang.toUpperCase()}
            </a>
          </li>
          <li class="nav-theme-toggle">
            <button
              class="navigation-link btn-reset"
              id="dark-mode-toggle"
              aria-label="Toggle theme"
              aria-pressed="false"
            >
              <i class="fa-solid fa-circle-half-stroke"></i>
            </button>
          </li>
        </ul>
      </div>
    </nav>

    <main class="content" id="main-content">
      <slot />
    </main>

    <footer class="footer">
      <small>
        © {new Date().getFullYear()} {SITE.author}
      </small>
    </footer>

    <script>
      const body = document.body;
      const darkModeToggle = document.getElementById("dark-mode-toggle");
      const menuToggle = document.getElementById("menu-toggle");
      const navigationList = document.getElementById("navigation-list");
      const darkModeMediaQuery = window.matchMedia("(prefers-color-scheme: dark)");

      const scrollProgress = document.getElementById("scroll-progress");

      type MermaidApi = {
        initialize: (options: {
          startOnLoad: boolean;
          theme: string;
          securityLevel: string;
          themeVariables?: {
            fontFamily?: string;
            fontSize?: string;
          };
        }) => void;
        run: (options: { querySelector: string; suppressErrors: boolean }) => void | Promise<void>;
      };

      function loadScript(src: string, id?: string): Promise<void> {
        return new Promise<void>((resolve, reject) => {
          if (id && document.getElementById(id)) {
            resolve();
            return;
          }

          const script = document.createElement("script");
          script.src = src;
          script.async = true;
          if (id) {
            script.id = id;
          }
          script.onload = () => resolve();
          script.onerror = () => reject(new Error(`Failed to load script: ${src}`));
          document.head.appendChild(script);
        });
      }

      // Set initial layout and menu theme preference
      function setTheme(theme: "light" | "dark") {
        body.classList.remove("colorscheme-auto", "colorscheme-light", "colorscheme-dark");
        body.classList.add(`colorscheme-${theme}`);
        document.documentElement.style.colorScheme = theme;
        darkModeToggle?.setAttribute("aria-pressed", theme === "dark" ? "true" : "false");
      }

      const remembered = localStorage.getItem("colorscheme");
      if (remembered === "light" || remembered === "dark") {
        setTheme(remembered);
      } else {
        setTheme(darkModeMediaQuery.matches ? "dark" : "light");
      }

      // Navbar interactions
      darkModeToggle?.addEventListener("click", () => {
        const nextTheme = body.classList.contains("colorscheme-dark") ? "light" : "dark";
        setTheme(nextTheme);
        localStorage.setItem("colorscheme", nextTheme);
      });

      menuToggle?.addEventListener("click", () => {
        const isOpen = navigationList?.classList.toggle("is-open");
        menuToggle?.classList.toggle("is-active");
        menuToggle?.setAttribute("aria-expanded", isOpen ? "true" : "false");
        document.body.style.overflow = isOpen ? "hidden" : "";
      });

      // Close mobile menu on link click
      navigationList?.querySelectorAll("a").forEach(link => {
        link.addEventListener("click", () => {
          navigationList.classList.remove("is-open");
          menuToggle?.classList.remove("is-active");
          menuToggle?.setAttribute("aria-expanded", "false");
          document.body.style.overflow = "";
        });
      });

      // Interactive Features: Scroll Progress and reveal animations
      window.addEventListener("scroll", () => {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        if (scrollProgress) {
          scrollProgress.style.width = scrolled + "%";
        }
      });

      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.markdown-content h2, .markdown-content h3, .markdown-content p, .article-cover, .render-card, .reveal-on-scroll').forEach(el => {
        el.classList.add('reveal-on-scroll');
        revealObserver.observe(el);
      });

      // Code Block Copy Button
      document.querySelectorAll('pre').forEach(block => {
        const container = document.createElement('div');
        container.className = 'code-container';
        if (!block.parentNode) {
          return;
        }

        block.parentNode.insertBefore(container, block);
        container.appendChild(block);

        const button = document.createElement('button');
        button.className = 'copy-code-btn';
        button.innerHTML = '<i class="fa-regular fa-copy"></i>';
        container.appendChild(button);

        button.addEventListener('click', async () => {
          const codeElement = block.querySelector('code');
          if (!codeElement) {
            return;
          }

          const code = codeElement.innerText;
          await navigator.clipboard.writeText(code);
          button.innerHTML = '<i class="fa-solid fa-check"></i>';
          setTimeout(() => {
            button.innerHTML = '<i class="fa-regular fa-copy"></i>';
          }, 2000);
        });
      });

      // Handle TOC toggle on mobile
      document.addEventListener("click", (e) => {
        const target = e.target;
        if (target && target instanceof HTMLElement && target.classList.contains("toc-dropdown-toggle")) {
          const dropdown = target.nextElementSibling;
          if (dropdown && dropdown.classList.contains("toc-dropdown")) {
            dropdown.classList.toggle("is-open");
            target.classList.toggle("is-active");
          }
        }
      });

      darkModeMediaQuery.addEventListener("change", (event) => {
        if (!localStorage.getItem("colorscheme")) {
          setTheme(event.matches ? "dark" : "light");
        }
      });

      document.addEventListener("DOMContentLoaded", async () => {
        document.body.classList.remove("preload-transitions");

        // Initialize Mermaid diagrams
        const mermaidBlocks = document.querySelectorAll('pre code.language-mermaid');
        if (mermaidBlocks.length > 0) {
          const mermaid = (await import('mermaid')).default;

          const isDark = document.body.classList.contains('colorscheme-dark') ||
            (document.body.classList.contains('colorscheme-auto') &&
              window.matchMedia('(prefers-color-scheme: dark)').matches);
          mermaid.initialize({
            startOnLoad: false,
            theme: isDark ? 'dark' : 'default',
            securityLevel: 'loose',
            flowchart: {
              useMaxWidth: false,
            },
            sequence: {
              useMaxWidth: false,
            },
            gantt: {
              useMaxWidth: false,
            },
            er: {
              useMaxWidth: false,
            },
            themeVariables: {
              fontFamily: 'Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif',
              fontSize: '14px',
            },
          });

          mermaidBlocks.forEach((block) => {
            const pre = block.parentElement;
            if (!pre || !pre.parentNode) {
              return;
            }

            const code = block.textContent?.trim() || "";
            const newPre = document.createElement('pre');
            newPre.className = 'mermaid';
            newPre.textContent = code;
            pre.parentNode.replaceChild(newPre, pre);
          });

          await mermaid.run({
            querySelector: '.mermaid',
            suppressErrors: true,
          });

          // After rendering: only strip Mermaid's inline max-width so the
          // block container's overflow-x:auto can scroll the SVG correctly.
          document.querySelectorAll('.mermaid svg').forEach((svg) => {
            const el = svg as SVGElement;
            el.style.removeProperty('max-width');
          });
        }
      });
    </script>
  </body>
</html>